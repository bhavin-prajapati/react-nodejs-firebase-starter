# Example environment for the React + Node + Firestore starter.
# Copy to `.env` and adjust as needed: `cp .env.example .env`
# These values mirror CONTRACT.md and the defaults baked into docker-compose.yml.

# ---------------------------------------------------------------------------
# API (api/ — Express + functions-framework + firebase-admin)
# ---------------------------------------------------------------------------
# Port the functions-framework listens on (application containers use 8080).
PORT=8080
# Name of the HTTP function target registered by the API.
FUNCTION_TARGET=api
# GCP / Firestore project id (matches the Firebase emulator project).
GOOGLE_CLOUD_PROJECT=demo-starter
# Local/compose ONLY: point firebase-admin at the Firestore emulator.
# Leave this UNSET in production so the API uses real Firestore.
FIRESTORE_EMULATOR_HOST=firebase:8081
# Local/compose ONLY: point firebase-admin at the Auth emulator.
# Leave this UNSET in production so the API uses real Firebase Auth.
FIREBASE_AUTH_EMULATOR_HOST=firebase:9099

# ---------------------------------------------------------------------------
# Frontend (frontend/ — Vite + React)
# ---------------------------------------------------------------------------
# Base URL the SPA uses to reach the API; routes are called as
# `${VITE_API_BASE_URL}/api/items`. For local Compose dev this is the host
# mapping of the api service.
VITE_API_BASE_URL=http://localhost:8080

# Firebase client SDK configuration.
# These are safe to commit — they identify the project but do not grant access.
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=demo-starter.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=demo-starter
