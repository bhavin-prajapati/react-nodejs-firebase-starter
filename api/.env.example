# Port the API listens on (functions-framework). Containers use 8080.
PORT=8080

# Name of the functions-framework HTTP target (the Express app).
FUNCTION_TARGET=api

# Google Cloud / Firebase project id. Matches the Firestore project.
GOOGLE_CLOUD_PROJECT=demo-starter

# Local/Compose only: point the Admin SDK at the Firestore emulator.
# Leave this UNSET in production so Application Default Credentials are used.
FIRESTORE_EMULATOR_HOST=firebase:8081
