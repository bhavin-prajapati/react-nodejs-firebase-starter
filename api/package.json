{
  "name": "rnf-api",
  "version": "1.0.0",
  "private": true,
  "description": "Express + functions-framework + firebase-admin API for the React/Node/Firestore starter.",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "functions-framework --target=api --source=dist --port=${PORT:-8080}",
    "dev": "npm run build && npm run start",
    "lint": "eslint .",
    "test": "jest --ci"
  },
  "dependencies": {
    "@google-cloud/functions-framework": "^3.4.5",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "firebase-admin": "^12.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.11",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0"
  }
}
