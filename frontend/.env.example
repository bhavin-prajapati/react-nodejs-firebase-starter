# Base URL of the API the frontend talks to.
# The frontend calls API routes as `${VITE_API_BASE_URL}/api/items`.
# For local Docker Compose development this is the API published on the host:
VITE_API_BASE_URL=http://localhost:8080

# Firebase configuration for the client SDK.
# These values are safe to commit — they identify the project but do not grant
# access. For local emulator development the defaults below work out of the box.
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=demo-starter.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=demo-starter
